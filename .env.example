# Local credentials. Copy from .env locally; do not commit real values.

# Twilio voice / Media Streams
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WEBHOOK_BASE_URL=

# Gemini Live + video understanding
GEMINI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_LIVE_MODEL=models/gemini-3.1-flash-live-preview
GEMINI_VIDEO_MODEL=gemini-3.5-flash

# Notion
NOTION_API_KEY=
NTN_GATEWAY_PAGE_ID=
NTN_GATEWAY_DATA_REPO=
TECHNICAL_READING_DATA_SOURCE_ID=
NOTION_TECHNICAL_READING_URL=

# Sendblue API
SENDBLUE_CREDENTIALS_PATH=~/.sendblue/credentials.json
SENDBLUE_API_KEY_ID=
SENDBLUE_API_SECRET_KEY=
SENDBLUE_API_API_KEY=
SENDBLUE_API_API_SECRET=
SENDBLUE_FROM_NUMBER=
SENDBLUE_DEFAULT_TO=
SENDBLUE_ACCOUNT_EMAIL=
SENDBLUE_ACCOUNT=
SENDBLUE_COMPANY_ID=

# Demo defaults
DEMO_USER_PHONE=
DEMO_USER_PHONE_DISPLAY=
DEMO_AGENT_PERSONA="Warm, concise, and action-oriented. Ask what is on Freds mind, then capture exactly one follow-up action."
